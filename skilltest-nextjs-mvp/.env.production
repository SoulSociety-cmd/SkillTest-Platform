# MongoDB Atlas (Vercel integration)
MONGODB_URI=your_atlas_connection_string

# NextAuth Production (generate secret: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=https://your-vercel-app.vercel.app

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Sentry (https://sentry.io/settings/projects/skilltest-nextjs/keys/)
SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=skilltest
SENTRY_PROJECT=skilltest-nextjs

# PostHog (https://app.posthog.com/project/YOUR_PROJECT/api_keys)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OpenAI (from local)
OPENAI_API_KEY=your_openai_key

# NODE_ENV
NODE_ENV=production
