# SkillTest Platform Production Environment
# Copy to .env and customize for your deployment

# MongoDB Replica Set
MONGO_URI=mongodb://root:skilltest2024_prod@mongodb1:27017,mongodb2:27017,mongodb3:27017/skilltest?authSource=admin&replicaSet=rs0&authMechanism=DEFAULT&readPreference=secondaryPreferred

# Redis Session Cache
REDIS_URL=redis://skilltest2024_prod@redis:6379/0
SESSION_SECRET=your-super-secret-session-key-change-in-production

# JWT & Security
JWT_SECRET=skilltest-jwt-prod-2024-supersecret-key-change-this-immediately
FRONTEND_URL=https://your-skilltest-domain.com
API_URL=https://your-skilltest-domain.com/api

# App Config
NODE_ENV=production
PORT=5000

# Vite Frontend (build-time)
VITE_API_URL=https://your-skilltest-domain.com/api
VITE_SOCKET_URL=wss://your-skilltest-domain.com

# OpenAI (for AI grading)
OPENAI_API_KEY=your-openai-key-here

# Railway/DO (optional)
RAILWAY_ENVIRONMENT_ID=
RAILWAY_SERVICE_TOKEN=
DO_ACCESS_TOKEN=
DO_APP_ID=

# Rate Limits
RATE_LIMIT_WINDOW_MS=15 * 60 * 1000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=50

# Usage:
# cp .env.production .env
# Edit secrets/domains
# docker compose -f docker-compose.prod.yml up -d

